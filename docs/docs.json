{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "kensa",
  "description": "Kensa is the open source harness for evaluating your agents.",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "colors": {
    "primary": "#090909",
    "light": "#f3f3f3",
    "dark": "#949494"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "icon": "play",
        "root": "getting-started",
        "directory": "card",
        "pages": [
          "introduction",
          "quickstart",
          "concepts",
          "examples"
        ]
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "root": "reference",
        "directory": "accordion",
        "pages": [
          "scenarios",
          "checks",
          "judge",
          "tracing"
        ]
      },
      {
        "group": "Workflows",
        "icon": "workflow",
        "root": "workflows",
        "directory": "card",
        "pages": [
          "skills",
          "cli",
          "mcp",
          "ci"
        ]
      },
      {
        "group": "Releases",
        "icon": "history",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/satyaborg/kensa"
      }
    ],
    "primary": {
      "type": "button",
      "label": "kensa.sh",
      "href": "https://kensa.sh"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/satyaborg/kensa",
      "x": "https://x.com/kensa_sh",
      "discord": "https://discord.gg/n77EqxUH"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "Kensa docs",
      "twitter:site": "@kensa_sh"
    },
    "indexing": "all"
  }
}
