{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet .",
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://kensa.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://kensa.mintlify.dev/docs/:match*"
    }
  ]
}
